# Environment Variables for Production
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
MONGODB_URI=mongodb+srv://your-username:your-password@cluster.mongodb.net/maalem?retryWrites=true&w=majority
PORT=5001
NODE_ENV=production

# CORS Configuration
FRONTEND_URL=https://your-domain.com

# File Upload Configuration
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100
